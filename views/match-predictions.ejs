<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>โพยทายผล - <%= match.home_team %> vs <%= match.away_team %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #f8fafc; --surface: #ffffff; --text: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --primary: #2563eb; }
        body { font-family: 'Prompt', sans-serif; background-color: var(--bg); color: var(--text); margin: 0; padding: 10px; font-size: 0.9rem; }
        .container { max-width: 100vw; padding: 0 10px; box-sizing: border-box; }
        
        .top-nav-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; max-width: 1200px; margin-left: auto; margin-right: auto; }
        .nav-link { color: var(--primary); text-decoration: none; font-weight: 600; font-size: 0.95rem; }
        .nav-link:hover { text-decoration: underline; }
        
        .card { background: var(--surface); border-radius: 12px; padding: 15px 0; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); border: 1px solid var(--border); overflow: hidden; }
        .card h2 { text-align: center; color: var(--text); margin-top: 5px; margin-bottom: 5px; font-size: 1.4rem; }
        .card p.subtitle { text-align: center; color: var(--text-muted); margin-bottom: 20px; font-size: 0.95rem; }
        
        .table-wrapper { overflow-x: auto; max-width: 100%; border-top: 1px solid var(--border); padding-bottom: 10px; }
        table { border-collapse: collapse; min-width: max-content; }
        th, td { border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); padding: 12px 10px; text-align: center; }
        
        thead th { background-color: var(--bg); font-weight: 600; position: sticky; top: 0; z-index: 10; border-bottom: 2px solid var(--border); }
        thead th.user-th { padding: 10px 6px; min-width: 70px; max-width: 90px; }
        .user-th img { width: 36px; height: 36px; border-radius: 50%; border: 2px solid #cbd5e1; object-fit: cover; margin-bottom: 5px; }
        .user-th .username { display: block; color: var(--text); font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        
        .sticky-col { position: sticky; left: 0; background-color: var(--surface); z-index: 20; text-align: left; min-width: 180px; max-width: 250px; box-shadow: 2px 0 4px rgba(0,0,0,0.05); vertical-align: middle; }
        thead .sticky-col { z-index: 30; background-color: var(--bg); vertical-align: bottom; padding-bottom: 12px; }
        
        .match-info { font-weight: 600; color: var(--text); font-size: 0.95rem; display: flex; flex-direction: column; gap: 4px; white-space: nowrap; }
        .match-stage { display: block; font-size: 0.75rem; color: var(--text-muted); font-weight: 400; margin-bottom: 6px; }
        .actual-score { color: #16a34a; font-weight: 700; background: #dcfce7; padding: 4px 10px; border-radius: 6px; font-size: 0.9rem; display: inline-block; margin-top: 8px; border: 1px solid #bbf7d0;}
        .pending-score { color: #854d0e; font-weight: 600; background: #fef9c3; padding: 4px 10px; border-radius: 6px; font-size: 0.85rem; display: inline-block; margin-top: 8px; border: 1px solid #fef08a;}
        
        .pred-box { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; }
        .pred-val { font-family: monospace; font-weight: 700; font-size: 1.1rem; letter-spacing: 1px; color: #334155; }
        .score-badge { font-size: 0.75rem; font-weight: 700; padding: 2px 10px; border-radius: 10px; min-width: 30px; display: inline-block; }
        
        /* แยกระดับสีคะแนน */
        .score-exact { background-color: #f59e0b; color: white; box-shadow: 0 2px 4px rgba(245, 158, 11, 0.3); } /* สีส้ม: ทายสกอร์เป๊ะ */
        .score-success { background-color: #10b981; color: white; box-shadow: 0 2px 4px rgba(16, 185, 129, 0.3); } /* สีเขียว: ทายถูกทิศทาง */
        .score-zero { background-color: #f1f5f9; color: #64748b; } /* สีเทา: ทายผิด / ไม่ได้แต้ม */
        
        tbody tr:hover td { background-color: #f8fafc; }
        tbody tr:hover .sticky-col { background-color: #f8fafc; }
    </style>
</head>
<body>
    <div class="container">
        <div class="top-nav-bar">
            <a href="/" class="nav-link">⬅️ กลับหน้าหลักทายผล</a>
            <% if (user.is_admin === 1) { %>
                <a href="/admin" class="nav-link" style="color: #4f46e5;">⚙️ กลับแผงควบคุม Admin</a>
            <% } %>
        </div>
        
        <div class="card">
            <h2>🔍 โพยทายผลเพื่อนร่วมแก๊ง</h2>
            <p class="subtitle">แมตช์: <strong style="color: var(--primary);"><%= match.home_team %> vs <%= match.away_team %></strong></p>
            
            <% if(predictions.length === 0) { %>
                <div style="text-align: center; padding: 30px; color: var(--text-muted);">ยังไม่มีผู้เล่นคนใดทายผลแมตช์นี้</div>
            <% } else { %>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th class="sticky-col">
                                    <div style="font-size: 0.85rem; color: var(--text-muted);">ข้อมูลแมตช์</div>
                                </th>
                                <% predictions.forEach(p => { %>
                                    <th class="user-th">
                                        <img src="<%= p.avatar %>" alt="avatar" title="<%= p.username %>">
                                        <span class="username" title="<%= p.username %>"><%= p.username %></span>
                                    </th>
                                <% }) %>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <!-- คอลัมน์แมตช์ (ล็อกซ้าย) -->
                                <td class="sticky-col">
                                    <span class="match-stage"><%= match.stage_name %></span>
                                    <div class="match-info">
                                        <span>🏠 <%= match.home_team %></span>
                                        <span>✈️ <%= match.away_team %></span>
                                    </div>
                                    <% if(match.status === 'FINISHED') { %>
                                        <span class="actual-score">ผลจริง: <%= match.home_score %> - <%= match.away_score %></span>
                                    <% } else { %>
                                        <span class="pending-score">รอผลการแข่งขัน</span>
                                    <% } %>
                                </td>
                                
                                <!-- คอลัมน์ผู้เล่นแต่ละคน -->
                                <% predictions.forEach(p => { 
                                    let isExact = false;
                                    let isCorrect = false;
                                    let hasResult = match.status === 'FINISHED' && match.home_score !== null;

                                    if (hasResult && p.home_predict !== null) {
                                        isExact = (p.home_predict === match.home_score && p.away_predict === match.away_score);
                                        
                                        let actualResult = match.home_score > match.away_score ? 'H' : (match.home_score < match.away_score ? 'A' : 'D');
                                        let predResult = p.home_predict > p.away_predict ? 'H' : (p.home_predict < p.away_predict ? 'A' : 'D');
                                        isCorrect = (actualResult === predResult);
                                    }
                                %>
                                    <td>
                                        <% if(p.home_predict !== null && p.away_predict !== null) { %>
                                            <div class="pred-box">
                                                <span class="pred-val" style="<%= isExact && hasResult ? 'color: #d97706;' : (isCorrect && hasResult ? 'color: #15803d;' : '') %>">
                                                    <%= p.home_predict %> - <%= p.away_predict %>
                                                </span>
                                                
                                                <% if(hasResult) { %>
                                                    <% if(isExact) { %>
                                                        <span class="score-badge score-exact">+<%= p.score_earned %> แต้ม</span>
                                                    <% } else if(isCorrect) { %>
                                                        <span class="score-badge score-success">+<%= p.score_earned %> แต้ม</span>
                                                    <% } else { %>
                                                        <span class="score-badge score-zero">0 แต้ม</span>
                                                    <% } %>
                                                <% } else { %>
                                                    <span class="score-badge score-zero" style="background: #e2e8f0;">รอผล</span>
                                                <% } %>
                                            </div>
                                        <% } else { %>
                                            <span style="color: #cbd5e1; font-size: 1.5rem;">-</span>
                                        <% } %>
                                    </td>
                                <% }) %>
                            </tr>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>