<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>โพยของ <%= targetUser.username %></title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #f8fafc; --surface: #ffffff; --text: #0f172a; --text-muted: #64748b; --primary: #2563eb; --border: #e2e8f0; }
        body { font-family: 'Prompt', sans-serif; background-color: var(--bg); color: var(--text); margin: 0; padding: 20px; }
        .container { max-width: 1000px; margin: 0 auto; }
        .header-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 20px 30px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); }
        .user-info { display: flex; align-items: center; gap: 15px; }
        .user-info img { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; border: 3px solid var(--primary); }
        .user-info h2 { margin: 0; font-size: 1.5rem; color: var(--text); }
        .nav-link { color: var(--primary); text-decoration: none; font-weight: 600; }
        
        table { width: 100%; border-collapse: collapse; background: var(--surface); border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); border: 1px solid var(--border); }
        th, td { padding: 16px; text-align: left; border-bottom: 1px solid var(--border); }
        th { background-color: #f1f5f9; font-weight: 600; color: var(--text-muted); }
        .team-name { font-weight: 600; font-size: 1.05rem; }
        .score-box { background: #f1f5f9; padding: 6px 16px; border-radius: 8px; font-weight: 700; display: inline-block; border: 1px solid var(--border); letter-spacing: 2px;}
        .hidden-badge { color: #f59e0b; background: #fef3c7; padding: 4px 8px; border-radius: 6px; font-size: 0.85rem; font-weight: 500; }
        
        .date-group { margin-bottom: 24px; }
        .date-header { padding: 12px 16px; background: var(--primary); color: white; font-weight: 600; border-radius: 8px 8px 0 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header-card">
            <div class="user-info">
                <img src="<%= targetUser.avatar %>" alt="Avatar">
                <div>
                    <p style="margin: 0; color: var(--text-muted); font-size: 0.9rem;">กำลังดูการทายผลของ</p>
                    <h2><%= targetUser.username %></h2>
                </div>
            </div>
            <a href="/leaderboard" class="nav-link">⬅️ กลับตารางคะแนนรวม</a>
        </div>

        <% 
            const groupedMatches = {};
            matches.forEach(m => {
                const dateStr = m.kickoff_time.substring(0, 10);
                if(!groupedMatches[dateStr]) groupedMatches[dateStr] = [];
                groupedMatches[dateStr].push(m);
            });
            const dates = Object.keys(groupedMatches).sort();
        %>

        <% if(dates.length === 0) { %>
            <div style="text-align: center; padding: 40px; color: var(--text-muted); background: var(--surface); border-radius: 12px;">ยังไม่มีข้อมูลการทายผล</div>
        <% } else { %>
            <% dates.forEach(date => { %>
                <div class="date-group">
                    <div class="date-header">📅 แมตช์วันที่ <%= date %></div>
                    <table>
                        <thead><tr><th width="20%">รอบ/เวลา</th><th width="35%">คู่แข่งขัน</th><th width="20%">การทายผล</th><th width="25%">ผลคะแนนที่ได้</th></tr></thead>
                        <tbody>
                            <% groupedMatches[date].forEach(match => { %>
                                <tr>
                                    <td><span style="color: var(--text-muted);"><%= match.stage_name %></span><br><small><%= match.kickoff_time.substring(11, 16) %> น.</small></td>
                                    <td><span class="team-name"><%= match.home_team %></span> <span style="color: var(--text-muted); margin: 0 5px;">vs</span> <span class="team-name"><%= match.away_team %></span></td>
                                    <td>
                                        <% if(match.is_hidden) { %>
                                            <span class="hidden-badge">🔒 ซ่อนอยู่ (รอเริ่มแข่ง)</span>
                                        <% } else if(match.home_predict !== null && match.away_predict !== null) { %>
                                            <div class="score-box"><%= match.home_predict %> - <%= match.away_predict %></div>
                                        <% } else { %>
                                            <span style="color: #94a3b8;">ยังไม่ทายผล</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if(match.status === 'FINISHED') { %>
                                            <strong style="color: <%= match.score_earned > 0 ? '#10b981' : '#ef4444' %>;">
                                                <%= match.score_earned > 0 ? `+${match.score_earned} แต้ม` : '0 แต้ม' %>
                                            </strong>
                                            <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 4px;">ผลจริง: <%= match.home_score %>-<%= match.away_score %></div>
                                        <% } else { %>
                                            <span style="color: var(--text-muted);">-</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% }) %>
        <% } %>
    </div>
</body>
</html>