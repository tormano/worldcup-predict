<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ตารางคะแนนละเอียด - World Cup 2026</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #f8fafc; --surface: #ffffff; --text: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --primary: #2563eb; }
        body { font-family: 'Prompt', sans-serif; background-color: var(--bg); color: var(--text); margin: 0; padding: 10px; font-size: 0.85rem; }
        .container { max-width: 100vw; padding: 0 10px; box-sizing: border-box; }
        
        .top-nav-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; max-width: 1200px; margin-left: auto; margin-right: auto; }
        .nav-link { color: var(--primary); text-decoration: none; font-weight: 600; font-size: 0.9rem; }
        .nav-link:hover { text-decoration: underline; }
        
        .card { background: var(--surface); border-radius: 12px; padding: 10px 0; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); border: 1px solid var(--border); overflow: hidden; }
        .card h2 { text-align: center; color: var(--text); margin-top: 5px; margin-bottom: 10px; font-size: 1.25rem; }
        
        .table-wrapper { overflow-x: auto; max-width: 100%; border-top: 1px solid var(--border); max-height: 80vh; }
        table { border-collapse: collapse; min-width: max-content; }
        th, td { border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); padding: 4px 6px; text-align: center; }
        
        thead th { background-color: var(--bg); font-weight: 600; position: sticky; top: 0; z-index: 10; border-bottom: 2px solid var(--border); }
        thead th.user-th { padding: 4px; min-width: 55px; max-width: 70px; }
        .user-th img { width: 24px; height: 24px; border-radius: 50%; border: 1px solid #cbd5e1; object-fit: cover; margin-bottom: 2px; }
        .user-th .username { display: block; color: var(--text); font-size: 0.7rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .user-th .score { display: block; color: var(--primary); font-size: 0.75rem; font-weight: 700; background: #eff6ff; border-radius: 4px; margin-top: 2px; padding: 1px 0; }
        
        .sticky-col { position: sticky; left: 0; background-color: var(--surface); z-index: 20; text-align: left; min-width: 160px; max-width: 200px; box-shadow: 2px 0 4px rgba(0,0,0,0.05); }
        thead .sticky-col { z-index: 30; background-color: var(--bg); vertical-align: bottom; padding-bottom: 8px; }
        
        .match-info { font-weight: 600; color: var(--text); font-size: 0.8rem; display: flex; justify-content: space-between; align-items: center; white-space: nowrap; }
        .match-stage { display: block; font-size: 0.65rem; color: var(--text-muted); font-weight: 400; margin-bottom: 1px; }
        .actual-score { color: #16a34a; font-weight: 700; background: #dcfce7; padding: 1px 4px; border-radius: 4px; font-size: 0.75rem; margin: 0 4px; }
        
        .pred-box { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1px; }
        .pred-val { font-family: monospace; font-weight: 600; font-size: 0.85rem; letter-spacing: 0.5px; color: #334155; }
        .score-badge { font-size: 0.65rem; font-weight: 700; padding: 1px 4px; border-radius: 8px; min-width: 16px; }
        .score-success { background-color: #10b981; color: white; } /* สีเขียว: ถูกทิศทาง */
        .score-exact { background-color: #f59e0b; color: white; } /* สีส้ม: สกอร์เป๊ะ */
        .score-zero { background-color: #f1f5f9; color: #94a3b8; }
        
        tbody tr:hover td { background-color: #f8fafc; }
        tbody tr:hover .sticky-col { background-color: #f8fafc; }

        /* สีและแถบแบ่งสำหรับ Match Day */
        .matchday-row th { background-color: #e2e8f0; padding: 6px 10px; font-weight: 600; border-bottom: 2px solid #cbd5e1; }
        .matchday-row .sticky-col { z-index: 25; color: var(--primary); font-size: 0.85rem; }
    </style>
</head>
<body>
    <div class="container">
        <div class="top-nav-bar">
            <a href="/leaderboard" class="nav-link">⬅️ กลับตารางคะแนนรวม (ปกติ)</a>
            <a href="/" class="nav-link">🏠 หน้าหลักทายผล</a>
        </div>
        
        <div class="card">
            <h2>🔍 ตารางเปรียบเทียบผลการทายแบบละเอียด</h2>
            
            <% 
                // ฟังก์ชันคำนวณ Match Day (ตัดยอดตอน 12:00 น.)
                const getMatchDayInfo = (kickoffTime) => {
                    let dateObj = new Date(kickoffTime);
                    let hour = dateObj.getHours();
                    let year = dateObj.getFullYear();
                    let month = dateObj.getMonth();
                    let date = dateObj.getDate();
                    
                    let startDay = new Date(year, month, date, 12, 0, 0);
                    if (hour < 12) startDay.setDate(startDay.getDate() - 1);
                    
                    let endDay = new Date(startDay);
                    endDay.setDate(endDay.getDate() + 1);
                    
                    const pad = n => n.toString().padStart(2, '0');
                    return {
                        sortKey: `${startDay.getFullYear()}-${pad(startDay.getMonth()+1)}-${pad(startDay.getDate())}`,
                        displayLabel: `${pad(startDay.getDate())}/${pad(startDay.getMonth()+1)} 12:00 น. ถึง ${pad(endDay.getDate())}/${pad(endDay.getMonth()+1)} 12:00 น.`
                    };
                };

                const groupedMatches = {};
                const groupLabels = {};
                
                // จัดกลุ่มแมตช์ที่แข่งจบแล้ว
                matches.forEach(m => {
                    const info = getMatchDayInfo(m.kickoff_time);
                    if(!groupedMatches[info.sortKey]) {
                        groupedMatches[info.sortKey] = [];
                        groupLabels[info.sortKey] = info.displayLabel;
                    }
                    groupedMatches[info.sortKey].push(m);
                });
                
                // จัดเรียงรอบที่เตะล่าสุดมาอยู่ด้านบน (Reverse Sort)
                const datesToDisplay = Object.keys(groupedMatches).sort().reverse();
            %>

            <% if(matches.length === 0) { %>
                <div style="text-align: center; padding: 30px; color: var(--text-muted);">ยังไม่มีข้อมูลแมตช์ที่แข่งขันจบแล้ว</div>
            <% } else if(users.length === 0) { %>
                <div style="text-align: center; padding: 30px; color: var(--text-muted);">ยังไม่มีข้อมูลผู้เข้าแข่งขัน</div>
            <% } else { %>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th class="sticky-col">
                                    <div style="font-size: 0.75rem; color: var(--text-muted);">แมตช์ที่แข่งจบแล้ว</div>
                                </th>
                                <% users.forEach(u => { %>
                                    <th class="user-th">
                                        <img src="<%= u.avatar %>" alt="avatar" title="<%= u.username %>">
                                        <span class="username" title="<%= u.username %>"><%= u.username %></span>
                                        <span class="score"><%= u.total_score %> pts</span>
                                    </th>
                                <% }) %>
                            </tr>
                        </thead>
                        <tbody>
                            <% datesToDisplay.forEach(date => { %>
                                <!-- แถบหัวข้อ Match Day แบ่งแต่ละกลุ่ม -->
                                <tr class="matchday-row">
                                    <th class="sticky-col">📅 <%= groupLabels[date] %></th>
                                    <th colspan="<%= users.length %>"></th>
                                </tr>

                                <!-- วนลูปแมตช์ใน Match Day นั้นๆ -->
                                <% groupedMatches[date].sort((a, b) => b.id - a.id).forEach(m => { %>
                                    <tr>
                                        <!-- คอลัมน์แมตช์ (ล็อกซ้าย) -->
                                        <td class="sticky-col">
                                            <span class="match-stage"><%= m.stage_name %></span>
                                            <div class="match-info">
                                                <span><%= m.home_team %></span>
                                                <span class="actual-score"><%= m.home_score %>-<%= m.away_score %></span>
                                                <span><%= m.away_team %></span>
                                            </div>
                                        </td>
                                        
                                        <!-- คอลัมน์ผู้เล่นแต่ละคน -->
                                        <% users.forEach(u => { 
                                            const p = predMap[m.id] && predMap[m.id][u.id];
                                            let isExact = false;
                                            if (p && p.home_predict !== null && m.home_score !== null) {
                                                isExact = (p.home_predict === m.home_score && p.away_predict === m.away_score);
                                            }
                                        %>
                                            <td>
                                                <% if(p && p.home_predict !== null && p.away_predict !== null) { %>
                                                    <div class="pred-box">
                                                        <span class="pred-val" style="<%= isExact ? 'color: #d97706;' : '' %>"><%= p.home_predict %>-<%= p.away_predict %></span>
                                                        <% if(p.score_earned > 0) { %>
                                                            <span class="score-badge <%= isExact ? 'score-exact' : 'score-success' %>">+<%= p.score_earned %></span>
                                                        <% } else { %>
                                                            <span class="score-badge score-zero">0</span>
                                                        <% } %>
                                                    </div>
                                                <% } else { %>
                                                    <span style="color: #cbd5e1; font-size: 1rem;">-</span>
                                                <% } %>
                                            </td>
                                        <% }) %>
                                    </tr>
                                <% }) %>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>