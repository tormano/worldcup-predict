<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ตารางคะแนนละเอียด - World Cup 2026</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #f8fafc; --surface: #ffffff; --text: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --primary: #2563eb; }
        body { font-family: 'Prompt', sans-serif; background-color: var(--bg); color: var(--text); margin: 0; padding: 20px; }
        .container { max-width: 100vw; padding: 0 20px; box-sizing: border-box; }
        
        .top-nav-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; max-width: 1200px; margin-left: auto; margin-right: auto; }
        .nav-link { color: var(--primary); text-decoration: none; font-weight: 600; font-size: 1.05rem; }
        .nav-link:hover { text-decoration: underline; }
        
        .card { background: var(--surface); border-radius: 16px; padding: 20px 0; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); border: 1px solid var(--border); overflow: hidden; }
        .card h2 { text-align: center; color: var(--text); margin-top: 10px; margin-bottom: 20px; font-size: 1.8rem; }
        
        .table-wrapper { overflow-x: auto; max-width: 100%; border-top: 1px solid var(--border); }
        table { border-collapse: collapse; min-width: max-content; }
        th, td { border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); padding: 12px 10px; text-align: center; font-size: 0.95rem; }
        
        thead th { background-color: var(--bg); font-weight: 600; position: sticky; top: 0; z-index: 10; border-bottom: 2px solid var(--border); }
        thead th.user-th { padding: 10px; min-width: 80px; }
        .user-th img { width: 40px; height: 40px; border-radius: 50%; border: 2px solid #cbd5e1; object-fit: cover; margin-bottom: 5px; }
        .user-th .username { display: block; color: var(--text); font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px; margin: 0 auto; }
        .user-th .score { display: block; color: var(--primary); font-size: 0.85rem; font-weight: 700; }
        
        .sticky-col { position: sticky; left: 0; background-color: var(--surface); z-index: 20; text-align: left; min-width: 200px; box-shadow: 4px 0 6px -2px rgba(0,0,0,0.05); }
        thead .sticky-col { z-index: 30; background-color: var(--bg); }
        
        .sub-th { background-color: #f1f5f9 !important; font-size: 0.8rem !important; color: var(--text-muted); padding: 6px !important; }
        .td-pred { background-color: #fafafa; font-weight: 500; font-family: monospace; letter-spacing: 1px; font-size: 1rem; }
        .td-score { font-weight: 700; font-size: 1rem; }
        
        .match-info { font-weight: 600; color: var(--text); font-size: 1.05rem; }
        .match-stage { display: block; font-size: 0.8rem; color: var(--text-muted); font-weight: 400; margin-top: 4px; }
        .actual-score { color: #16a34a; }
    </style>
</head>
<body>
    <div class="container">
        <div class="top-nav-bar">
            <a href="/leaderboard" class="nav-link">⬅️ กลับตารางคะแนนรวม (ปกติ)</a>
            <a href="/" class="nav-link">🏠 หน้าหลักทายผล</a>
        </div>
        <div class="card">
            <h2>🔍 ตารางเปรียบเทียบผลการทายแบบละเอียด</h2>
            <% if(matches.length === 0) { %><div style="text-align: center; padding: 40px; color: var(--text-muted);">ยังไม่มีข้อมูลแมตช์ที่แข่งขันจบแล้วในระบบ</div>
            <% } else if(users.length === 0) { %><div style="text-align: center; padding: 40px; color: var(--text-muted);">ยังไม่มีข้อมูลผู้เข้าแข่งขัน</div>
            <% } else { %>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th class="sticky-col" rowspan="2" style="vertical-align: bottom; padding-bottom: 20px;">
                                    แมตช์การแข่งขัน<br><span style="color: var(--text-muted); font-weight: 400; font-size: 0.85rem;">(ผลสกอร์จริง)</span>
                                </th>
                                <% users.forEach(u => { %>
                                    <th colspan="2" class="user-th">
                                        <img src="<%= u.avatar %>" alt="avatar"><span class="username"><%= u.username %></span><span class="score"><%= u.total_score %> แต้ม</span>
                                    </th>
                                <% }) %>
                            </tr>
                            <tr>
                                <% users.forEach(u => { %><th class="sub-th">ทายผล</th><th class="sub-th" style="border-right-width: 2px;">ได้แต้ม</th><% }) %>
                            </tr>
                        </thead>
                        <tbody>
                            <% matches.forEach(m => { %>
                                <tr>
                                    <td class="sticky-col">
                                        <div class="match-info"><%= m.home_team %> <span class="actual-score"><%= m.home_score %> - <%= m.away_score %></span> <%= m.away_team %></div>
                                        <span class="match-stage"><%= m.stage_name %></span>
                                    </td>
                                    <% users.forEach(u => { const p = predMap[m.id] && predMap[m.id][u.id]; %>
                                        <td class="td-pred"><% if(p && p.home_predict !== null && p.away_predict !== null) { %><%= p.home_predict %> - <%= p.away_predict %><% } else { %><span style="color: #cbd5e1;">-</span><% } %></td>
                                        <td class="td-score" style="border-right-width: 2px;">
                                            <% if(p && p.score_earned > 0) { %><span style="color: #10b981;">+<%= p.score_earned %></span>
                                            <% } else if(p && p.score_earned === 0 && p.home_predict !== null) { %><span style="color: #ef4444;">0</span>
                                            <% } else { %><span style="color: #cbd5e1;">-</span><% } %>
                                        </td>
                                    <% }) %>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>