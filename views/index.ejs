<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ทายผลบอลโลก World Cup 2026</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #f8fafc; --surface: #ffffff; --text: #0f172a; --text-muted: #64748b; --primary: #2563eb; --primary-hover: #1d4ed8; --border: #e2e8f0; }
        body { font-family: 'Prompt', sans-serif; background-color: var(--bg); color: var(--text); margin: 0; padding: 20px; }
        .container { max-width: 1000px; margin: 0 auto; }
        .header-card { background: linear-gradient(135deg, #1e293b, #0f172a); color: white; border-radius: 16px; padding: 20px 30px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1); }
        .user-info { display: flex; align-items: center; gap: 15px; }
        .user-info img { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; border: 3px solid #38bdf8; background: #fff; }
        .user-info h3 { margin: 0; font-size: 1.2rem; }
        .user-info p { margin: 0; color: #94a3b8; font-size: 0.9rem; }
        .nav-links a { color: white; text-decoration: none; font-weight: 500; margin-left: 20px; transition: color 0.2s; }
        .nav-links a:hover { color: #38bdf8; } .nav-links a.admin-link { color: #86efac; } .nav-links a.logout-link { color: #fca5a5; }
        
        .card-title { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20px; background: var(--surface); padding: 20px; border-radius: 12px; border: 1px solid var(--border);}
        .card-title h2 { margin: 0; color: var(--text); font-size: 1.5rem; }
        
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 16px; text-align: left; border-bottom: 1px solid var(--border); }
        th { background-color: var(--bg); font-weight: 600; color: var(--text-muted); }
        .team-name { font-weight: 600; font-size: 1.05rem; }
        .vs { color: var(--text-muted); margin: 0 8px; font-size: 0.9rem; }
        input[type="number"] { width: 60px; padding: 8px; border: 1px solid var(--border); border-radius: 8px; text-align: center; font-family: inherit; font-size: 1rem; transition: 0.2s; }
        input[type="number"]:focus { outline: none; border-color: var(--primary); }
        
        /* สไตล์สำหรับช่องที่ถูกล็อกไว้หลังจากทายผล (แต่ยังแก้ได้ถ้ากดปุ่ม) */
        input[readonly] { background-color: #f1f5f9; color: #334155; font-weight: 600; border-color: transparent; cursor: default; }
        input[readonly]:focus { outline: none; border-color: transparent; }
        /* สไตล์สำหรับช่องที่ถูกล็อกถาวร (บอลเตะแล้ว) */
        input:disabled { background-color: #e2e8f0; color: #94a3b8; cursor: not-allowed; border-color: transparent; }
        
        .btn { padding: 8px 16px; background-color: var(--primary); color: white; border: none; border-radius: 8px; font-family: inherit; font-weight: 500; cursor: pointer; transition: 0.2s; text-decoration: none; display: inline-block;}
        .btn:hover { background-color: var(--primary-hover); }
        .btn-view { background-color: #10b981; } .btn-view:hover { background-color: #059669; }
        .btn-edit { background-color: #f59e0b; } .btn-edit:hover { background-color: #d97706; }
        
        .locked-badge { color: #94a3b8; font-size: 0.9rem; display: flex; align-items: center; gap: 5px; }

        .date-group { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 16px; overflow: hidden; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); }
        .date-header { padding: 16px 20px; background: #f8fafc; font-weight: 600; cursor: pointer; user-select: none; font-size: 1.1rem; color: var(--primary); transition: background 0.2s; }
        .date-header:hover { background: #f1f5f9; }
        .date-group[open] .date-header { border-bottom: 1px solid var(--border); }
        .date-content table { margin-bottom: 0; border-style: hidden; }
        .date-content th { background: #ffffff; border-bottom: 2px solid var(--border); }

        /* สไตล์สำหรับ Message Box (Popup Modal) */
        .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15, 23, 42, 0.6); display: flex; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px); opacity: 0; visibility: hidden; transition: 0.3s; }
        .modal-overlay.active { opacity: 1; visibility: visible; }
        .modal-box { background: var(--surface); padding: 30px; border-radius: 16px; width: 90%; max-width: 400px; text-align: center; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); transform: translateY(20px); transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        .modal-overlay.active .modal-box { transform: translateY(0); }
        .modal-icon { font-size: 3rem; margin-bottom: 15px; display: block; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header-card">
            <div class="user-info">
                <img src="<%= user.avatar %>" alt="Avatar">
                <div><p>ยินดีต้อนรับ</p><h3><%= user.username %></h3></div>
            </div>
            <div class="nav-links">
                <a href="/leaderboard">📊 ตารางคะแนนรวม</a>
                <% if(user.is_admin) { %> <a href="/admin" class="admin-link">⚙️ แผงควบคุม (Admin)</a> <% } %>
                <a href="/logout" class="logout-link">ออกจากระบบ</a>
            </div>
        </div>

        <div class="card-title">
            <h2 style="margin: 0;">🏆 ตารางแข่งขันและการทายผล</h2>
            <small>⏱️ ล็อกผลอัตโนมัติเมื่อการแข่งขันเริ่มขึ้น</small>
        </div>

        <% 
            // คำนวณหาวันที่ T+1 (พรุ่งนี้) โดยอิงจากเวลาประเทศไทย
            const getThaiDateString = (offsetDays = 0) => {
                const d = new Date(new Date().getTime() + (7 * 60 * 60 * 1000) + (offsetDays * 24 * 60 * 60 * 1000));
                return d.toISOString().substring(0, 10);
            };
            const maxDateStr = getThaiDateString(1); // วันพรุ่งนี้ (T+1)

            const groupedMatches = {};
            matches.forEach(m => {
                const dateStr = m.kickoff_time.substring(0, 10);
                
                // กรองแสดงเฉพาะแมตช์ที่แข่งขันไม่เกิน T+1 (รวมถึงวันนี้และแมตช์ในอดีต)
                if (dateStr <= maxDateStr) {
                    if(!groupedMatches[dateStr]) groupedMatches[dateStr] = [];
                    groupedMatches[dateStr].push(m);
                }
            });
            
            // จัดเรียงวันที่โดยให้ วันที่ล่าสุด มากอด (Descending)
            const dates = Object.keys(groupedMatches).sort().reverse();
        %>

        <% if(dates.length === 0) { %>
            <div style="text-align: center; padding: 40px; color: var(--text-muted); background: var(--surface); border-radius: 12px; border: 1px solid var(--border);">ยังไม่มีตารางการแข่งขันเปิดให้ทายผลในขณะนี้</div>
        <% } else { %>
            <% dates.forEach(date => { %>
                <details class="date-group" open>
                    <summary class="date-header">📅 แมตช์วันที่ <%= date %></summary>
                    <div class="date-content">
                        <table>
                            <thead><tr><th width="15%">รอบ/เวลา</th><th width="30%">คู่แข่งขัน</th><th width="15%">ผลจริง</th><th width="25%">การทายผลของคุณ</th><th width="15%">ดูของเพื่อน</th></tr></thead>
                            <tbody>
                                <% groupedMatches[date].forEach(match => { %>
                                    <% const hasPredicted = match.home_predict !== null && match.home_predict !== undefined; %>
                                    <tr>
                                        <td><span style="color: var(--text-muted);"><%= match.stage_name %></span><br><small><%= match.kickoff_time.substring(11, 16) %> น.</small></td>
                                        <td><span class="team-name"><%= match.home_team %></span> <span class="vs">vs</span> <span class="team-name"><%= match.away_team %></span></td>
                                        <td>
                                            <% if(match.status === 'FINISHED') { %> <span style="color: #16a34a; font-weight: 700; font-size: 1.1rem;"><%= match.home_score %> - <%= match.away_score %></span>
                                            <% } else { %> <span style="color: var(--text-muted);">-</span> <% } %>
                                        </td>
                                        <td>
                                            <!-- เปลี่ยนเป็นการเรียกใช้ JS Function เมื่อกด submit -->
                                            <form action="/predict" method="POST" style="margin:0; display:flex; gap:10px; align-items:center;" onsubmit="submitPrediction(event, this)">
                                                <input type="hidden" name="match_id" value="<%= match.id %>">
                                                
                                                <input type="number" id="home-<%= match.id %>" name="home_predict" value="<%= match.home_predict %>" 
                                                    <% if(match.is_locked) { %>disabled<% } else if(hasPredicted) { %>readonly<% } %> required> :
                                                
                                                <input type="number" id="away-<%= match.id %>" name="away_predict" value="<%= match.away_predict %>" 
                                                    <% if(match.is_locked) { %>disabled<% } else if(hasPredicted) { %>readonly<% } %> required>
                                                
                                                <% if(!match.is_locked) { %> 
                                                    <% if(hasPredicted) { %>
                                                        <!-- แสดงปุ่มแก้ไข ถ้าเคยทายไปแล้ว -->
                                                        <button type="button" class="btn btn-edit" id="btn-edit-<%= match.id %>" onclick="enableEdit(<%= match.id %>)">แก้ไข</button>
                                                        <button type="submit" class="btn" id="btn-save-<%= match.id %>" style="display:none;">บันทึก</button>
                                                    <% } else { %>
                                                        <!-- แสดงปุ่มบันทึก ถ้ายังไม่เคยทาย -->
                                                        <button type="submit" class="btn" id="btn-save-<%= match.id %>">บันทึก</button>
                                                    <% } %>
                                                <% } else { %> 
                                                    <div class="locked-badge">🔒 ล็อกแล้ว</div> 
                                                <% } %>
                                            </form>
                                            
                                            <% if(match.status === 'FINISHED') { %>
                                                <div style="margin-top: 8px; font-size: 0.95rem; font-weight: 600; color: <%= match.score_earned > 0 ? '#10b981' : '#ef4444' %>;">
                                                    <%= match.score_earned > 0 ? `+${match.score_earned} แต้ม 🎉` : '0 แต้ม 😢' %>
                                                </div>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if(match.is_published) { %>
                                                <a href="/match/<%= match.id %>/predictions" class="btn btn-view">👁️ ดูคำทายเพื่อน</a>
                                            <% } else { %>
                                                <small style="color: var(--text-muted);">🔒 รอยืนยัน</small>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </details>
            <% }) %>
        <% } %>
    </div>

    <!-- Custom Modal สำหรับแจ้งเตือน -->
    <div id="customModal" class="modal-overlay">
        <div class="modal-box">
            <span class="modal-icon">⏳</span>
            <h3 style="margin-top:0; color: var(--text); font-size: 1.3rem;">แจ้งเตือน</h3>
            <p id="modalMessage" style="color: var(--text-muted); margin-bottom: 25px;"></p>
            <button class="btn" style="width: 100%; padding: 10px;" onclick="closeModal()">ตกลง และอัปเดตหน้าจอ</button>
        </div>
    </div>

    <script>
        function enableEdit(matchId) {
            const homeInput = document.getElementById('home-' + matchId);
            const awayInput = document.getElementById('away-' + matchId);
            const editBtn = document.getElementById('btn-edit-' + matchId);
            const saveBtn = document.getElementById('btn-save-' + matchId);

            // ปลดล็อกสถานะ readonly
            homeInput.removeAttribute('readonly');
            awayInput.removeAttribute('readonly');

            // สลับปุ่มแก้ไข เป็น ปุ่มบันทึก
            editBtn.style.display = 'none';
            saveBtn.style.display = 'inline-block';

            // โฟกัสไปที่ช่องทีมเหย้าให้พร้อมพิมพ์
            homeInput.focus();
            homeInput.select(); // คลุมดำตัวเลขเดิมให้พิมพ์ทับได้เลย
        }

        // ฟังก์ชันดักจับการกดปุ่ม "บันทึก" เพื่อเช็ค Error จาก Server (AJAX)
        async function submitPrediction(event, form) {
            event.preventDefault(); // หยุดการโหลดหน้าเว็บใหม่ทันที
            
            const formData = new FormData(form);
            const data = new URLSearchParams(formData);

            try {
                // ส่งข้อมูลไปเซฟที่ Backend
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: data,
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
                });

                if (response.redirected) {
                    // ถ้าระบบบันทึกสำเร็จ (Backend สั่งให้ Redirect กลับหน้าหลัก)
                    window.location.href = response.url;
                } else if (!response.ok) {
                    // ถ้าเกิด Error (เช่น 400 ปิดรับการทายผลแล้ว)
                    const errorText = await response.text();
                    showModal(errorText); // แสดง Popup แทนการเด้งไปหน้าจอขาว
                } else {
                    window.location.reload();
                }
            } catch (err) {
                showModal('เกิดข้อผิดพลาดในการเชื่อมต่อกับเซิร์ฟเวอร์');
            }
        }

        function showModal(message) {
            document.getElementById('modalMessage').innerText = message;
            document.getElementById('customModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('customModal').classList.remove('active');
            window.location.reload(); // รีเฟรชหน้าเพื่ออัปเดตให้ปุ่มนั้นกลายเป็น "🔒 ล็อกแล้ว"
        }
    </script>
</body>
</html>