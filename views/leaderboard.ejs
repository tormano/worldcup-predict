<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Table - World Cup 2026</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { 
            --pl-bg: #37003c;
            --pl-nav: #240028;
            --pl-surface: rgba(255, 255, 255, 0.03);
            --pl-text: #ffffff; 
            --pl-text-muted: #cbd5e1; 
            --pl-border: rgba(255, 255, 255, 0.1); 
            --pl-primary: #00ff85; 
            --pl-accent: #04f5ff;
        }
        body { font-family: 'Prompt', sans-serif; background-color: var(--pl-bg); color: var(--pl-text); margin: 0; padding: 0; font-size: 0.9rem; }
        
        .pl-header { background-color: var(--pl-nav); border-bottom: 1px solid var(--pl-border); position: sticky; top: 0; z-index: 100; transition: all 0.3s ease; }
        .nav-container { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; padding: 0 15px; height: 60px; }
        .nav-brand { display: flex; align-items: center; }
        .brand-logo { height: 40px; filter: brightness(0) invert(1); } 
        
        .nav-menu { display: flex; gap: 20px; height: 100%; align-items: center; }
        .nav-item { color: var(--pl-text); text-decoration: none; font-weight: 600; font-size: 0.95rem; height: 100%; display: flex; align-items: center; border-bottom: 3px solid transparent; transition: 0.2s; }
        .nav-item:hover { color: var(--pl-primary); }
        .nav-item.active { border-bottom-color: var(--pl-primary); }
        .admin-link { color: #86efac; }
        
        .nav-profile { display: flex; align-items: center; }
        .profile-dropdown { display: flex; align-items: center; gap: 10px; }
        .avatar-img { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 1px solid var(--pl-border); }
        .profile-info { display: flex; flex-direction: column; }
        .profile-name { font-size: 0.85rem; font-weight: 600; }
        .logout-text { font-size: 0.75rem; color: #fca5a5; text-decoration: none; }

        .page-banner { padding: 35px 20px; color: white; background: linear-gradient(90deg, #963cff 0%, #04f5ff 100%); transition: all 0.3s ease; overflow: hidden; }
        .banner-content { max-width: 1000px; margin: 0 auto; }
        .banner-content h1 { margin: 0; font-size: 2.5rem; font-weight: 700; letter-spacing: -0.5px; transition: all 0.3s ease; }
        .pl-header.scrolled .page-banner { padding: 10px 20px; }
        .pl-header.scrolled .banner-content h1 { font-size: 1.25rem; }

        .page-submenu { background-color: #2e0033; border-bottom: 1px solid var(--pl-border); }
        .submenu-content { max-width: 1000px; margin: 0 auto; display: flex; gap: 25px; padding: 0 15px; }
        .submenu-item { color: var(--pl-text-muted); text-decoration: none; padding: 12px 0; font-size: 0.95rem; font-weight: 500; border-bottom: 3px solid transparent; transition: 0.2s;}
        .submenu-item:hover { color: var(--pl-text); }
        .submenu-item.active { color: var(--pl-text); border-bottom-color: var(--pl-accent); font-weight: 600; }

        .main-content { max-width: 1000px; margin: 20px auto; padding: 0 15px 50px; }

        /* --- ปรับแต่งตารางให้เลื่อนในกล่องและแถวแคบลง --- */
        .card.table-wrapper { 
            background: var(--pl-surface); 
            border-radius: 12px; 
            border: 1px solid var(--pl-border); 
            max-height: 70vh; /* กำหนดความสูงเพื่อให้เลื่อนได้ในกล่อง */
            overflow-y: auto; 
            padding: 0; 
        }
        
        .pl-table { width: 100%; border-collapse: separate; border-spacing: 0; color: var(--pl-text); min-width: 700px;}
        
        /* Freeze Header (ล็อคหัวตาราง) */
        .pl-table th { 
            position: sticky;
            top: 0;
            z-index: 20;
            background: #240028; /* ต้องใช้สีทึบเพื่อบังแถวที่เลื่อนขึ้นมา */
            color: var(--pl-text-muted); 
            font-weight: 500; 
            padding: 8px 10px; /* บีบหัวตารางให้แคบลง */
            text-align: center; 
            border-bottom: 2px solid rgba(255,255,255,0.2); 
            font-size: 0.85rem;
            height: 44px; /* ล็อคความสูงเป๊ะๆ เพื่อคำนวณตำแหน่งแถวอันดับ 1 */
            box-sizing: border-box;
        }
        
        /* Narrower Rows (บีบแถวข้อมูลให้แคบลง) */
        .pl-table td { 
            padding: 6px 10px; /* ลด Padding บน-ล่าง จาก 15px เหลือ 6px */
            text-align: center; 
            border-bottom: 1px solid var(--pl-border); 
            transition: 0.2s; 
            vertical-align: middle;
            height: 48px; /* บังคับความสูงแถวไม่ให้ยืดเกินไป */
            box-sizing: border-box;
        }
        
        .pl-table th:nth-child(1), .pl-table td:nth-child(1) { text-align: left; padding-left: 25px;}
        .pl-table th:nth-child(2), .pl-table td:nth-child(2) { text-align: left; }
        .pl-table tr:hover td { background: rgba(255, 255, 255, 0.05); }

        /* ปรับขนาดฟอนต์และรูปให้เล็กลงรับกับแถวที่แคบลง */
        .rank-reward { font-size: 1.15rem; font-weight: 700; color: var(--pl-text); }
        .rank-normal { font-size: 0.95rem; font-weight: 500; color: var(--pl-text-muted); }
        .user-cell { display: flex; align-items: center; gap: 10px; }
        .user-cell img { width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--pl-border); object-fit: cover;}
        .user-cell .username { font-weight: 600; font-size: 0.9rem; }
        
        .reward-badge { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: 600; background: rgba(255,255,255,0.05); border: 1px solid var(--pl-border); }
        .shared-badge { font-size: 0.6rem; background: rgba(0,0,0,0.4); padding: 2px 4px; border-radius: 4px; color: var(--pl-text-muted); font-weight: 500; margin-left: 4px;}

        /* --- Freeze Rank 1 (ล็อคแถวอันดับ 1) --- */
        .sticky-rank-1 td {
            position: sticky;
            top: var(--sticky-top); /* ถูกคำนวณและสั่งผ่าน HTML */
            z-index: 15;
            background-color: #3b0040 !important; /* พื้นหลังสีม่วงทึบให้โดดเด่นและบังแถวล่าง */
            border-bottom: 2px solid var(--pl-primary) !important;
            box-shadow: 0 4px 6px rgba(0,0,0,0.2);
        }
        .pl-table tr.sticky-rank-1:hover td {
            background-color: #51005c !important; /* สีตอนเอาเมาส์ชี้แถวอันดับ 1 */
        }

        @media (max-width: 768px) {
            .nav-menu { gap: 10px; }
            .nav-item { font-size: 0.85rem; }
        }
    </style>
</head>
<body>

    <header class="pl-header" id="mainHeader">
        <div class="nav-container">
            <div class="nav-brand">
                <img src="https://digitalhub.fifa.com/transform/157d23bf-7e13-4d7b-949e-5d27d340987e/WC26_Logo?&io=transform:fill&quality=75" alt="World Cup 2026 Logo" class="brand-logo">
            </div>
            <div class="nav-menu">
                <a href="/?tab=matches" class="nav-item">Matches</a>
                <a href="/?tab=fixtures" class="nav-item">Fixtures</a>
                <a href="/leaderboard" class="nav-item active">Table</a>
                <% if(typeof user !== 'undefined' && user && user.is_admin === 1) { %> 
                    <a href="/admin" class="nav-item admin-link">Admin</a> 
                <% } %>
            </div>
            <div class="nav-profile">
                <% if(typeof user !== 'undefined' && user) { %>
                <div class="profile-dropdown">
                    <img src="<%= user.avatar %>" alt="Avatar" class="avatar-img">
                    <div class="profile-info">
                        <span class="profile-name"><%= user.username %></span>
                        <a href="/logout" class="logout-text">Sign Out</a>
                    </div>
                </div>
                <% } %>
            </div>
        </div>

        <div class="page-banner">
            <div class="banner-content">
                <h1>Table</h1>
            </div>
        </div>

        <div class="page-submenu">
            <div class="submenu-content">
                <a href="/leaderboard" class="submenu-item active">Table</a>
                <a href="/leaderboard/detailed" class="submenu-item">View details</a>
            </div>
        </div>
    </header>

    <div class="main-content">
        <% try { %>
            <% const safeLeaderboard = (typeof leaderboard !== 'undefined' && Array.isArray(leaderboard)) ? leaderboard : []; %>
            <% if(safeLeaderboard.length === 0) { %>
                <div style="text-align: center; padding: 40px; color: var(--pl-text-muted);">ยังไม่มีข้อมูลคะแนนในระบบ</div>
            <% } else { %>
                <div class="card table-wrapper">
                    <table class="pl-table">
                        <thead>
                            <tr>
                                <th width="8%">Pos</th>
                                <th width="30%">Club / Player</th>
                                <th width="10%">MP</th>
                                <th width="12%">Exact</th>
                                <th width="12%">Result</th>
                                <th width="15%">Pts</th>
                                <th width="13%">Reward</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% 
                                // ตัวแปรสำหรับคำนวณตำแหน่งล็อค (Top) ของอันดับ 1
                                let currentStickyTop = 44; // เริ่มต่อจาก Header ที่มีความสูง 44px
                            %>
                            <% safeLeaderboard.forEach((row) => { %>
                                <% 
                                    const isRank1 = row.displayRank === 1;
                                    const rank1Class = isRank1 ? 'sticky-rank-1' : '';
                                    
                                    // หากเป็นอันดับ 1 ให้คำนวณตำแหน่ง Top แล้วบวกเพิ่มเผื่อกรณีมีคนได้ที่ 1 ร่วมกัน
                                    let myStickyTop = 0;
                                    if (isRank1) {
                                        myStickyTop = currentStickyTop;
                                        currentStickyTop += 48; // บวกเพิ่ม 48px (ความสูงของ 1 แถว) สำหรับที่ 1 คนถัดไป
                                    }

                                    const hasColor = row.reward && row.reward.color && row.reward.color !== '#ffffff';
                                    const rowBg = (!isRank1 && hasColor) ? `background-color: ${row.reward.color}15; border-left: 4px solid ${row.reward.color};` : (hasColor ? `border-left: 4px solid ${row.reward.color};` : '');
                                %>
                                <tr class="<%= rank1Class %>" style="cursor: pointer; --sticky-top: <%= myStickyTop %>px; <%= rowBg %>" onclick="window.location.href='/user/<%= row.id %>/predictions'">
                                    <td style="<%= hasColor ? 'border-left: none;' : '' %>">
                                        <% if(row.reward) { %>
                                            <span class="rank-reward"><%= row.displayRank %></span>
                                        <% } else { %>
                                            <span class="rank-normal"><%= row.displayRank %></span>
                                        <% } %>
                                        <% if(row.isTied) { %><br><span style="font-size: 0.65rem; color: var(--pl-text-muted);">(ร่วม)</span><% } %>
                                    </td>
                                    <td>
                                        <div class="user-cell">
                                            <img src="<%= row.avatar %>" alt="avatar">
                                            <span class="username"><%= row.username %></span>
                                        </div>
                                    </td>
                                    <td><%= row.mp %></td>
                                    <td><%= row.exact_score_count %></td>
                                    <td><%= row.correct_result_count %></td>
                                    <td><strong style="font-size: 1.15rem; color: var(--pl-primary);"><%= row.total_score || 0 %></strong></td>
                                    
                                    <% if (row.isFirstInGroup) { %>
                                        <td rowspan="<%= row.rowspan %>" style="vertical-align: middle; border-left: 1px solid var(--pl-border); background-color: inherit;">
                                            <% if(row.reward) { %>
                                                <div class="reward-badge" style="border-color: <%= hasColor ? row.reward.color : 'var(--pl-border)' %>;">
                                                    <span style="font-size: 1rem;"><%= row.reward.icon %></span>
                                                    <span><%= row.reward.description %></span>
                                                    <% if(row.rowspan > 1) { %><span class="shared-badge">แชร์ <%= row.rowspan %></span><% } %>
                                                </div>
                                            <% } else { %>
                                                <span style="color: var(--pl-border);">-</span>
                                            <% } %>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        <% } catch (error) { %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; padding: 20px; border-radius: 8px;">
                <h3 style="margin-top: 0;">⚠️ พบข้อผิดพลาดในการแสดงผล EJS</h3>
                <pre style="white-space: pre-wrap; font-size: 0.85rem;"><%= error.message %></pre>
            </div>
        <% } %>
    </div>

    <script>
        window.addEventListener('scroll', () => {
            const header = document.getElementById('mainHeader');
            if (header) {
                if (window.scrollY > 20) {
                    header.classList.add('scrolled');
                } else {
                    header.classList.remove('scrolled');
                }
            }
        });
    </script>
</body>
</html>