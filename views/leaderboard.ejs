<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ตารางคะแนนรวม - World Cup 2026</title>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root { --bg: #f8fafc; --surface: #ffffff; --text: #0f172a; --text-muted: #64748b; --border: #e2e8f0; --primary: #2563eb; }
        body { font-family: 'Prompt', sans-serif; background-color: var(--bg); color: var(--text); margin: 0; padding: 15px; font-size: 0.9rem; }
        .container { max-width: 1200px; margin: 0 auto; }
        
        .top-nav-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .nav-link { color: var(--primary); text-decoration: none; font-weight: 600; font-size: 0.95rem; }
        .nav-link:hover { text-decoration: underline; }
        
        .card { background: var(--surface); border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05); border: 1px solid var(--border); overflow: hidden;}
        .card h2 { text-align: center; color: var(--text); margin-top: 0; margin-bottom: 20px; font-size: 1.5rem; }
        
        table { width: 100%; border-collapse: collapse; min-width: 800px; }
        .table-responsive { overflow-x: auto; border-top: 1px solid var(--border); }
        th, td { padding: 12px 10px; text-align: center; border-bottom: 1px solid var(--border); vertical-align: middle; }
        th { background-color: var(--bg); font-weight: 600; color: var(--text-muted); font-size: 0.85rem; }
        
        .user-cell { display: flex; align-items: center; justify-content: flex-start; gap: 12px; text-align: left; }
        .user-cell img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid #cbd5e1; }
        
        .rank-cell { font-weight: 700; font-size: 1.1rem; color: #334155; }
        .score-cell { font-weight: 700; font-size: 1.1rem; color: var(--primary); }
        .stat-number { font-weight: 600; color: #475569; }
        .stat-score { font-weight: 600; color: #10b981; font-size: 0.85rem;}
        
        .reward-item { display: inline-flex; align-items: center; gap: 8px; background: #fff; padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; border: 1px solid var(--border); box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
        .reward-icon { font-size: 1.2rem; }
        .shared-badge { font-size: 0.7rem; background: #f1f5f9; color: #475569; padding: 2px 8px; border-radius: 10px; font-weight: 600; display: inline-block; margin-top: 6px; border: 1px solid #cbd5e1;}
        
        .btn { padding: 8px 16px; background-color: var(--primary); color: white; border: none; border-radius: 8px; font-family: inherit; font-weight: 600; cursor: pointer; transition: 0.2s; text-decoration: none; display: inline-block; font-size: 0.95rem;}
        .btn:hover { background-color: #1d4ed8; }
    </style>
</head>
<body>
    <div class="container">
        <div class="top-nav-bar">
            <a href="/" class="nav-link">⬅️ กลับหน้าหลัก</a>
            <% if (user.is_admin === 1) { %>
                <a href="/admin" class="nav-link" style="color: #4f46e5;">⚙️ แผงควบคุม Admin</a>
            <% } %>
        </div>

        <div style="text-align: center; margin-bottom: 20px;">
            <a href="/leaderboard/detailed" class="btn" style="background-color: #f59e0b;">🔍 ดูตารางคะแนนแบบละเอียด (เทียบทุกคน)</a>
        </div>
        
        <div class="card table-responsive">
            <h2>🏆 ตารางคะแนนรวม (Leaderboard)</h2>
            <table>
                <thead>
                    <tr>
                        <th width="8%">อันดับ</th>
                        <th width="20%" style="text-align: left;">ผู้เล่น</th>
                        <th width="8%">MP <span style="font-size: 0.7rem; cursor: help;" title="Match Played (ทายผลไปแล้วกี่คู่)">ℹ️</span></th>
                        <th width="10%">ทายผลถูก</th>
                        <th width="10%">คะแนนทายผลถูก</th>
                        <th width="10%">ทายสกอร์ถูก</th>
                        <th width="12%">คะแนนทายสกอร์ถูก</th>
                        <th width="12%" style="text-align: right;">คะแนนรวมทั้งหมด</th>
                        <th width="15%">รางวัลที่ได้รับ</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(leaderboard.length === 0) { %><tr><td colspan="9" style="text-align: center; padding: 25px; color: var(--text-muted);">ยังไม่มีข้อมูลคะแนนในระบบ</td></tr><% } %>
                    <% leaderboard.forEach((row) => { %>
                        <% 
                            const rewardInfo = row.reward;
                            const hasColor = rewardInfo && rewardInfo.color && rewardInfo.color !== '#ffffff';
                            const rowBg = hasColor ? `background-color: ${rewardInfo.color}15; border-left: 4px solid ${rewardInfo.color};` : '';
                        %>
                        <tr style="cursor: pointer; transition: background 0.2s; <%= rowBg %>" onclick="window.location.href='/user/<%= row.id %>/predictions'" onmouseover="this.style.backgroundColor='#f1f5f9'" onmouseout="this.style.backgroundColor='<%= hasColor ? rewardInfo.color + '15' : 'transparent' %>'">
                            <td class="rank-cell" style="<%= hasColor ? 'border-left: none;' : '' %>">
                                <% if(row.displayRank === 1) { %> 🥇 
                                <% } else if(row.displayRank === 2) { %> 🥈 
                                <% } else if(row.displayRank === 3) { %> 🥉 
                                <% } else { %> <%= row.displayRank %> <% } %>
                                
                                <% if(row.isTied) { %>
                                    <br><span style="font-size: 0.65rem; color: #64748b; font-weight: 500;">(ร่วม)</span>
                                <% } %>
                            </td>
                            <td><div class="user-cell"><img src="<%= row.avatar %>" alt="avatar"><span style="color: var(--primary); font-weight: 600;"><%= row.username %></span></div></td>
                            <td class="stat-number"><%= row.mp %></td>
                            <td class="stat-number"><%= row.correct_result_count %></td>
                            <td class="stat-score">+<%= row.correct_result_score %></td>
                            <td class="stat-number"><%= row.exact_score_count %></td>
                            <td class="stat-score">+<%= row.exact_score_score %></td>
                            <td class="score-cell" style="text-align: right;"><%= row.total_score || 0 %> แต้ม</td>
                            
                            <!-- ตรวจจับคนแรกของกลุ่ม เพื่อเปิดใช้ Rowspan -->
                            <% if (row.isFirstInGroup) { %>
                                <td rowspan="<%= row.rowspan %>" style="text-align: center; vertical-align: middle; border-left: 1px solid var(--border); background-color: inherit;">
                                    <% if(rewardInfo) { %>
                                        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
                                            <div class="reward-item" style="border-color: <%= hasColor ? rewardInfo.color : '#fde68a' %>;">
                                                <span class="reward-icon"><%= rewardInfo.icon %></span>
                                                <span><%= rewardInfo.description %></span>
                                            </div>
                                            <% if(row.isTied) { %>
                                                <span class="shared-badge">แชร์กัน <%= row.rowspan %> คน</span>
                                            <% } %>
                                        </div>
                                    <% } else { %>
                                        <span style="color: var(--border);">-</span>
                                    <% } %>
                                </td>
                            <% } %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>